# .env.example
# Copy to .env and customize for local scripts if needed.
# Never commit real secrets.

KUBECONFIG=~/.kube/config
CLUSTER_NAME=blueprint
# Used by some simulation / reporting scripts
ACTIVE_LEARNERS=180000
DEFAULT_CLOUD_PROVIDER=aws
# Cost simulation overrides
BASELINE_NODE_COST=0.85
SPOT_NODE_COST=0.29
